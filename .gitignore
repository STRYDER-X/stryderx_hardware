# --- ROS 2 Build Artifacts ---
# In case of local colcon builds within the package folder
build/
install/
log/
test_results/

# --- C++ Binary & Object Files ---
*.o
*.so
*.a
*.la
*.lo
*.out
bin/
lib/

# --- Python Artifacts (for ROS 2 nodes/scripts) ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- Linter & Formatting Logs ---
# These are generated by ament_lint during colcon test
ament_uncrustify/
ament_cpplint/
ament_cmake_doxygen/
cppcheck.xml

# --- Editor & IDE Specific ---
.vscode/
.vs/
.idea/
*.swp
*.bak
*~
.DS_Store

# --- Doxygen Documentation ---
# Keep your source, ignore the generated output
docs/html/
docs/latex/
*.dox

# --- ROS 2 Special ---
COLCON_IGNORE
